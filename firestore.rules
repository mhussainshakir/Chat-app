rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // A chatId is always "<uidA>_<uidB>" (sorted) — only those two users may touch it
    function isChatParticipant(chatId) {
      return isAuth() && request.auth.uid in chatId.split('_');
    }

    // Users collection - each user's profile
    match /users/{userId} {
      // Any signed-in user can read profiles (needed to search contacts by email)
      allow read: if isAuth();
      // Only the user can create/update their own profile
      allow write: if isOwner(userId);

      // Contacts subcollection - private to the owner
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Chats - top level collection, id = "<uidA>_<uidB>"
    match /chats/{chatId} {
      allow read, write: if isChatParticipant(chatId);

      match /messages/{messageId} {
        allow read, write: if isChatParticipant(chatId);
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
