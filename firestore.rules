rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isChatParticipant(chatId) {
      return isAuth() && request.auth.uid in chatId.split('_');
    }

    // ===== USERS =====
    match /users/{userId} {
      // Any signed-in user can read profiles (email search, presence/last-seen)
      allow read: if isAuth();
      // Only the user can create/update their own profile
      allow write: if isOwner(userId);

      // Contacts subcollection - fully private, owner decides names/who to keep
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ===== CONTACT REQUESTS =====
    // doc id = "<uidA>_<uidB>" sorted, so only these 2 users can ever touch it
    match /contactRequests/{reqId} {
      allow read: if isAuth() &&
                     (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuth() &&
                     (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
    }

    // ===== 1-TO-1 CHATS =====
    match /chats/{chatId} {
      allow read, write: if isChatParticipant(chatId);

      match /messages/{messageId} {
        allow read, write: if isChatParticipant(chatId);
      }
    }

    // ===== GROUPS =====
    match /groups/{groupId} {
      allow read: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth() && request.auth.uid in request.resource.data.members;
      allow update: if isAuth() && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow read, write: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
